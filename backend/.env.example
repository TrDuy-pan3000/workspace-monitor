# Biến môi trường & Secrets (QUAN TRỌNG: không bao giờ commit file này!)
# Copy file này thành .env và điền thông tin thật vào

# Cấu hình Telegram Bot cảnh báo
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Cấu hình kết nối AI (9Router hoặc OpenAI-compatible endpoint)
OPENAI_API_BASE=http://YOUR_9ROUTER_HOST:20128/v1
OPENAI_API_KEY=YOUR_API_KEY
MODEL_NAME=combo

# Múi giờ
TZ=Asia/Ho_Chi_Minh
